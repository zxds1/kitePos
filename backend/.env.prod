NODE_ENV=production
STORE_CORS=https://your-store.example.com
ADMIN_CORS=https://your-admin.example.com
AUTH_CORS=https://your-admin.example.com
REDIS_URL=redis://:replace_with_redis_password@your-redis-host:6379
JWT_SECRET=replace_with_strong_jwt_secret
COOKIE_SECRET=replace_with_strong_cookie_secret
DATABASE_URL=postgres://medusa:medusa_password@your-db-host:5432/medusa_db?sslmode=require
HASH_SALT=replace_with_strong_hash_salt
STOREFRONT_URL=https://your-store.example.com
ADMIN_URL=https://your-admin.example.com
PAYMENT_ENCRYPTION_KEY=replace_with_secure_key
ENABLE_REDIS=true
LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=
RAGFLOW_BASE_URL=http://ragflow:8080
RAGFLOW_WEB_URL=http://localhost:9380
RAGFLOW_API_KEY=replace_with_ragflow_api_key
AI_DEFAULT_MODEL=gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_FALLBACK_MODELS=["gpt-4o-mini","gpt-3.5-turbo","claude-3-haiku"]
ENABLE_OTEL=true
OTEL_EXPORTER=zipkin
OTEL_EXPORTER_ZIPKIN_ENDPOINT=http://localhost:9411/api/v2/spans
